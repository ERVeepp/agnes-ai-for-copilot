{
  "name": "agnes-ai-for-copilot-chat",
  "displayName": "Agnes AI - Copilot Chat Provider",
  "description": "Agnes AI 模型接入 VS Code Copilot Chat",
  "version": "0.1.1",
  "publisher": "erveepp",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ERVeepp/agnes-ai-for-copilot"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onUri",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "agnes-ai",
        "displayName": "Agnes AI"
      }
    ],
    "commands": [
      {
        "command": "agnes-ai-for-copilot-chat.setApiKey",
        "title": "Agnes AI: Set API Key"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.99.0",
    "@vscode/vsce": "^3.0.0",
    "sharp": "^0.35.2",
    "typescript": "^5.5.0"
  }
}
